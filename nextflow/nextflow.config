executor {
    perJobMemLimit = true
}

def scaledMemory = { baseMemory, maxMemory, attempt ->
    def baseGb = (baseMemory.toString().tokenize(' ')[0] as int)
    def maxGb = (maxMemory.toString().tokenize(' ')[0] as int)
    def requestedGb = baseGb * (1 << Math.max(0, (attempt as int) - 1))
    return "${Math.min(requestedGb, maxGb)} GB"
}

def safeInt = { value, fallback ->
    if (value instanceof Number) {
        return value.intValue()
    }
    def text = value?.toString()
    return (text != null && text ==~ /\d+/) ? Integer.parseInt(text) : fallback
}

def resolvedGpuQueue = System.getenv('MOCHI_GPU_QUEUE') ?: 'gpu-normal'
def resolvedGpuTime = System.getenv('MOCHI_GPU_TIME') ?: '12h'
def resolvedGpuClusterOptions = System.getenv('MOCHI_GPU_CLUSTER_OPTIONS') ?: ''
def resolvedMaxMemoryRetries = safeInt(System.getenv('MOCHI_MAX_MEMORY_RETRIES'), 3)
def resolvedParallelFolds = safeInt(System.getenv('MOCHI_PARALLEL_FOLDS'), 1)

def retryableMemoryExitCodes = ((130..145) as List<Integer>) + [104]

process {
    executor = "lsf"
    shell = ["/bin/bash", "-euo", "pipefail"]
    errorStrategy = "terminate"

    withLabel: mochi_gpu {
        queue = resolvedGpuQueue
        cpus = 1
        memory = "50 GB"
        if (resolvedGpuTime != 'NONE') {
            time = resolvedGpuTime
        }
        clusterOptions = resolvedGpuClusterOptions
    }

    withLabel: mochi_grid_gpu {
        queue = resolvedGpuQueue
        cpus = 1
        memory = { scaledMemory(params.grid_memory, params.grid_memory_max, task.attempt) }
        if (resolvedGpuTime != 'NONE') {
            time = resolvedGpuTime
        }
        clusterOptions = resolvedGpuClusterOptions
        maxRetries = resolvedMaxMemoryRetries
        errorStrategy = { retryableMemoryExitCodes.contains(task.exitStatus as Integer) ? 'retry' : 'terminate' }
    }

    withLabel: mochi_fold_gpu {
        queue = resolvedGpuQueue
        cpus = 1
        memory = { scaledMemory(params.fold_memory, params.fold_memory_max, task.attempt) }
        if (resolvedGpuTime != 'NONE') {
            time = resolvedGpuTime
        }
        clusterOptions = resolvedGpuClusterOptions
        maxForks = resolvedParallelFolds
        maxRetries = resolvedMaxMemoryRetries
        errorStrategy = { retryableMemoryExitCodes.contains(task.exitStatus as Integer) ? 'retry' : 'terminate' }
    }

    withLabel: summary_local {
        executor = "local"
        cpus = 1
        memory = "2 GB"
        time = "1h"
    }
}

cleanup = false

manifest {
    name = "mochi-lsf-benchmark"
}
