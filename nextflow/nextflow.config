executor {
    perJobMemLimit = true
}

def scaledMemory = { baseMemory, maxMemory, attempt ->
    def baseGb = (baseMemory.toString().tokenize(' ')[0] as int)
    def maxGb = (maxMemory.toString().tokenize(' ')[0] as int)
    def requestedGb = baseGb * (1 << Math.max(0, (attempt as int) - 1))
    return "${Math.min(requestedGb, maxGb)} GB"
}

def scaledGridMemory = { baseMemory, maxMemory, attempt ->
    def baseGb = (baseMemory.toString().tokenize(' ')[0] as int)
    def maxGb = (maxMemory.toString().tokenize(' ')[0] as int)
    def requestedGb = baseGb + (8 * Math.max(0, (attempt as int) - 1))
    return "${Math.min(requestedGb, maxGb)} GB"
}

def scaledRetryMemory = { baseMemory, maxMemory, attempt, maxRetries ->
    def baseGb = (baseMemory.toString().tokenize(' ')[0] as int)
    def maxGb = (maxMemory.toString().tokenize(' ')[0] as int)
    def totalAttempts = Math.max(1, (maxRetries as int) + 1)
    def attemptNum = attempt as int
    if (attemptNum >= totalAttempts) {
        return "${maxGb} GB"
    }
    def requestedGb = baseGb + (8 * Math.max(0, attemptNum - 1))
    return "${Math.min(requestedGb, maxGb)} GB"
}

def safeInt = { value, fallback ->
    if (value instanceof Number) {
        return value.intValue()
    }
    def text = value?.toString()
    return (text != null && text ==~ /\d+/) ? Integer.parseInt(text) : fallback
}

def configParam = { key, envKey, fallback ->
    params.containsKey(key) && params[key] != null && params[key].toString() != ""
        ? params[key]
        : (System.getenv(envKey) ?: fallback)
}

def resolvedGpuQueue = System.getenv('MOCHI_GPU_QUEUE') ?: 'gpu'
def resolvedGpuClusterOptions = System.getenv('MOCHI_GPU_CLUSTER_OPTIONS') ?: ''
def resolvedGridGpuClusterOptions = System.getenv('MOCHI_GRID_GPU_CLUSTER_OPTIONS') ?: (params.containsKey('grid_gpu_cluster_options') ? params.grid_gpu_cluster_options.toString() : resolvedGpuClusterOptions)
def resolvedFoldGpuClusterOptions = System.getenv('MOCHI_FOLD_GPU_CLUSTER_OPTIONS') ?: (params.containsKey('fold_gpu_cluster_options') ? params.fold_gpu_cluster_options.toString() : resolvedGpuClusterOptions)
def resolvedMaxMemoryRetries = safeInt(configParam('max_memory_retries', 'MOCHI_MAX_MEMORY_RETRIES', 3), 3)
def resolvedParallelFolds = safeInt(configParam('parallel_folds', 'MOCHI_PARALLEL_FOLDS', 1), 1)
def resolvedCpuQueue = configParam('cpu_queue', 'CPU_QUEUE', 'normal')
def resolvedGridMemory = configParam('grid_memory', 'GRID_MEMORY', '24 GB')
def resolvedGridMemoryMax = configParam('grid_memory_max', 'GRID_MEMORY_MAX', '50 GB')
def resolvedFoldMemory = configParam('fold_memory', 'FOLD_MEMORY', '24 GB')
def resolvedFoldMemoryMax = configParam('fold_memory_max', 'FOLD_MEMORY_MAX', '50 GB')
def resolvedMergeMemory = configParam('merge_memory', 'MERGE_MEMORY', '24 GB')
def resolvedMergeMemoryMax = configParam('merge_memory_max', 'MERGE_MEMORY_MAX', '50 GB')

def retryableMemoryExitCodes = ((130..145) as List<Integer>) + [104]

process {
    executor = "lsf"
    shell = ["/bin/bash", "-euo", "pipefail"]
    errorStrategy = "terminate"

    withLabel: mochi_gpu {
        queue = resolvedGpuQueue
        cpus = 1
        memory = "50 GB"
        clusterOptions = resolvedGpuClusterOptions
    }

    withLabel: mochi_grid_gpu {
        queue = resolvedGpuQueue
        cpus = 1
        memory = { scaledGridMemory(resolvedGridMemory, resolvedGridMemoryMax, task.attempt) }
        clusterOptions = resolvedGridGpuClusterOptions
        maxRetries = resolvedMaxMemoryRetries
        errorStrategy = {
            def retryable = retryableMemoryExitCodes.contains(task.exitStatus as Integer)
            (retryable && (task.attempt as int) <= resolvedMaxMemoryRetries) ? 'retry' : 'ignore'
        }
    }

    withLabel: mochi_fold_gpu {
        queue = resolvedGpuQueue
        cpus = 1
        memory = { scaledGridMemory(resolvedFoldMemory, resolvedFoldMemoryMax, task.attempt) }
        clusterOptions = resolvedFoldGpuClusterOptions
        maxForks = resolvedParallelFolds
        maxRetries = resolvedMaxMemoryRetries
        errorStrategy = {
            def retryable = retryableMemoryExitCodes.contains(task.exitStatus as Integer)
            (retryable && (task.attempt as int) <= resolvedMaxMemoryRetries) ? 'retry' : 'ignore'
        }
    }

    withLabel: summary_lsf_cpu {
        queue = resolvedCpuQueue
        cpus = 1
        memory = { scaledRetryMemory(resolvedMergeMemory, resolvedMergeMemoryMax, task.attempt, resolvedMaxMemoryRetries) }
        clusterOptions = ''
        maxRetries = resolvedMaxMemoryRetries
        errorStrategy = { retryableMemoryExitCodes.contains(task.exitStatus as Integer) ? 'retry' : 'terminate' }
    }
}

cleanup = false

manifest {
    name = "mochi-lsf-benchmark"
}
